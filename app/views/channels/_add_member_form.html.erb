<div id="add-member-form">
  <%= form_with url: add_user_path, method: :post, data: { turbo: true } do |f| %>
    <div class="search-add-user">
      <%= f.text_field :unique_id, placeholder: "@~ or name", class: "user-search-input", data: {action: "input->add-member#onInput", add_member_target: "input"}, value: undefind_user %>
      <%= f.submit '追加', class: "add-user-button" %>
    </div>
  <% end %>
  <% if undefind_user %>
    <p style="color: red">ユーザーが見つかりません</p>
  <% end %>

  <div id="suggest-list" class="suggest-list" data-add-member-target="suggest"></div>
</div>