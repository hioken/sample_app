<!-- ドロップダウンのトリガーのaタグは、本当はbuttonがいい(修正する気はない) -->
<header class="navbar navbar-fixed-top navbar-inverse">
  <div class="container">
    <%= link_to "sample app", root_path, id: "logo" %>
    <nav data-controller="menu">
      <button id="hamburger" type="button" class="navbar-toggle collapsed" data-action="click->menu#toggleMenu" data-toggle-class="collapse">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
      <ul id="navbar-menu"
          class="nav navbar-nav navbar-right collapse navbar-collapse">
        <li><%= link_to "Home", root_path %></li>
        <li><%= link_to "Help", help_path %></li>
        <% if logged_in? %>
          <li class="dropdown">
            <a href="#" id="user" class="dropdown-toggle" data-action="click->menu#toggleMenu" data-toggle-class="active">
              UserMenu <b class="caret"></b>
            </a>
            <ul id="dropdown-menu-user" class="dropdown-menu">
              <li><%= link_to "Users", users_path %></li>
              <li><%= link_to "following", following_user_path(current_user) %></li>
              <li><%= link_to "followers", followers_user_path(current_user) %></li>
              <li><%= link_to "message", channels_path %></li>
            </ul>
          </li>
          <li class="dropdown">
            <a href="#" id="account" class="dropdown-toggle" data-action="click->menu#toggleMenu" data-toggle-class="active">
              Account <b class="caret"></b>
            </a>
            <ul id="dropdown-menu-account" class="dropdown-menu">
              <li><%= link_to "Profile", current_user %></li>
              <li><%= link_to "Settings", edit_user_path(current_user) %></li>
              <li class="divider"></li>
              <li>
                <%= link_to "Log out", logout_path,
                                       data: { "turbo-method": :delete } %>
              </li>
            </ul>
          </li>
        <% else %>
          <li><%= link_to "Log in", login_path %></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
