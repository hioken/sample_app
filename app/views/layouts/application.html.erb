<!DOCTYPE html>
<html>
  <head>
    <title><%= full_title(yield(:title)) %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%= javascript_importmap_tags %>
    <%= yield :head %>
    <script type="module">
      // import "channels/notification_channel";
    </script>
  </head>
  <body>
    <% if logged_in? %>
      <%= turbo_stream_from "notification_#{current_user.id}" %>
      <div id="notification-container" class="notification-container" data-controller="message-notification"></div>
    <% end %>
    <%= render 'layouts/header' %>
    <div class="container">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= message_type %>"><%= message %></div>
      <% end %>
      <%= yield %>
      <%= render 'layouts/footer' %>
      <%= debug(params) if Rails.env.development? %>
      <p><%= "notification_#{current_user.id}" %></p>
    </div>
  </body>
</html>
